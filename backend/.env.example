# Ambiente de execucao
APP_ENV=development

# Conexao com o banco.
# Por padrao usamos SQLite local (arquivo na pasta backend) pra simplicidade.
# Quando for deploy/producao, troque por uma URL PostgreSQL:
#   postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=sqlite:///./curriculo_pdf.db

# Chave secreta para assinar JWTs. Use um valor aleatorio de pelo menos 32 chars.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=troque-isso-por-uma-string-longa-e-aleatoria-em-producao
JWT_ALGORITHM=HS256

# Access token tem vida curta (em minutos). Padrao: 15 min.
ACCESS_TOKEN_EXPIRA_MINUTOS=15

# Refresh token tem vida longa (em minutos). Padrao: 43200 = 30 dias.
REFRESH_TOKEN_EXPIRA_MINUTOS=43200

# Em producao com HTTPS, deixe true. Em dev local (http), false.
COOKIE_SECURE=false

# Cross-site cookies em producao podem precisar de "none". Em dev e mesmo
# site (localhost), "lax" e suficiente.
COOKIE_SAMESITE=lax

# Origens permitidas no CORS, separadas por virgula
CORS_ORIGINS=http://localhost:5173

# Chave da API do Google Gemini. Crie em aistudio.google.com -> Get API Key.
# Free tier oficial, sem cartao. Comeca com AIza...
# NUNCA commite o valor real, deixe esse exemplo vazio.
GOOGLE_API_KEY=

# Modelo Gemini usado para melhorar textos. gemini-2.5-flash e o padrao
# (free tier generoso, otima qualidade). Pode ajustar se quiser.
GEMINI_MODEL=gemini-2.5-flash
