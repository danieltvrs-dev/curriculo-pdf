# Ambiente de execucao
APP_ENV=development

# Conexao com o PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/curriculo_pdf

# Origens permitidas no CORS, separadas por virgula
CORS_ORIGINS=http://localhost:5173

# Chave da API da Anthropic (Claude). Crie em console.anthropic.com -> API Keys.
# Comeca com sk-ant-... NUNCA commite o valor real, so deixe esse exemplo vazio.
ANTHROPIC_API_KEY=

# Modelo Claude usado para melhorar textos. Sonnet 4.6 e o padrao
# (otimo custo/beneficio). Pra qualidade maxima trocar por claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6
